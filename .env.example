OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"
OPENAI_REASONING_EFFORT="low"
OPENAI_ASSISTANT_ENABLED="true"
MAKER_ACCESS_PASSWORD=""
MAKER_AUTH_PROVIDER="local"
# `supabase` 로 바꾸면 games/game_content 는 Supabase DB 를 쓰고,
# sessions 는 현재 단계에서는 계속 local JSON fallback 을 사용한다.
APP_PERSISTENCE_PROVIDER="local"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Alias names supported by the current maker auth config:
# SUPABASE_URL=""
# SUPABASE_PUBLISHABLE_KEY=""
# SUPABASE_SECRET_KEY=""
