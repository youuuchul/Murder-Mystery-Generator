MAKER_AUTH_PROVIDER="local"
# `supabase` 로 바꾸면 games/game_content/sessions 를 Supabase DB 로 읽고 쓴다.
# 먼저 `20260330_000002_create_games_and_game_content.sql`,
# `20260330_000003_create_sessions.sql` 을 콘솔에 적용해야 한다.
APP_PERSISTENCE_PROVIDER="local"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_ASSETS_BUCKET="game-assets"
SUPABASE_CONTENT_BACKUPS_BUCKET="game-content-backups"
SUPABASE_SESSION_BACKUPS_BUCKET="session-backups"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
# 비워두면 현재 요청이 들어온 도메인을 기준으로 재설정 링크를 만든다.
MAKER_RECOVERY_BASE_URL=""
# Legacy alias names supported during the migration period:
# SUPABASE_URL=""
# SUPABASE_PUBLISHABLE_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# Vercel Cron(24h 세션 자동 정리) 보호 토큰. 미설정 시 해당 엔드포인트가 500 거부.
CRON_SECRET=""

# 화면 설계서 Google Sheet 동기화 (`npm run sync:screens`). 로컬에서만 사용.
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON 은 JSON 전체를 한 줄 문자열로 저장.
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=""
