#!/bin/sh
# Keep docs/STATUS.md aligned with implementation updates.
# Override once only when absolutely necessary:
#   SKIP_STATUS_HOOK=1 git commit ...

set -eu

if [ "${SKIP_STATUS_HOOK:-0}" = "1" ]; then
  exit 0
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

work_pattern='^(src/|supabase/|scripts/|app/|public/|middleware.ts$|next\.config\.mjs$|package.json$|package-lock.json$|docs/backlog/|docs/plans/|docs/operations/|AGENTS.md$|CLAUDE.md$)'

if ! printf '%s\n' "$staged_files" | grep -Eq "$work_pattern"; then
  exit 0
fi

if printf '%s\n' "$staged_files" | grep -Fxq 'docs/STATUS.md'; then
  exit 0
fi

if git diff --quiet -- docs/STATUS.md; then
  cat >&2 <<'EOM'
[pre-commit] 작업 변경이 감지됐지만 docs/STATUS.md 변경이 없습니다.
작업 상태와 STATUS를 맞춘 뒤 커밋하세요.

- STATUS 수정 후: git add docs/STATUS.md
- 예외로 1회 건너뛰기(권장하지 않음): SKIP_STATUS_HOOK=1 git commit ...
EOM
else
  cat >&2 <<'EOM'
[pre-commit] docs/STATUS.md가 수정되어 있지만 스테이징되지 않았습니다.
작업 상태 일치를 위해 STATUS를 스테이징한 뒤 커밋하세요.

- 스테이징: git add docs/STATUS.md
- 예외로 1회 건너뛰기(권장하지 않음): SKIP_STATUS_HOOK=1 git commit ...
EOM
fi

exit 1
